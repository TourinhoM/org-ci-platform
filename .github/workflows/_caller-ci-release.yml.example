name: CI - Release

on:
  push:
    branches:
      - main

jobs:
  ci:
    permissions:
      contents: write
      issues: write
      pull-requests: write
    uses: TourinhoM/org-ci-platform/.github/workflows/ci-release.yml@v1
    secrets:
      # Opcional. Sem isso, tag criada por semantic-release nao dispara ci-tag.yml
      # (push via GITHUB_TOKEN nao gera novos workflow runs — safety do GitHub).
      # Configurar tambem var RELEASE_APP_ID no repo (Settings -> Variables -> Actions).
      RELEASE_APP_PRIVATE_KEY: ${{ secrets.RELEASE_APP_PRIVATE_KEY }}