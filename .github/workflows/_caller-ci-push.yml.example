name: CI - Push

on:
  push:
    branches:
      - '**'
      - '!main'

jobs:
  ci:
    permissions:
      contents: read
      security-events: write
      actions: read
      packages: write
    uses: TourinhoM/org-ci-platform/.github/workflows/ci-push.yml@main
    with:
      coverage-exclusions: ${{ vars.SONAR_COVERAGE_EXCLUSIONS }}
    secrets:
      SONAR_TOKEN: ${{ secrets.SONAR_TOKEN }}