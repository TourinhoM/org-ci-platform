{{- /* Engine xr (Caminho B): a intenção vira um único CR App; quem compõe os
   recursos é a composition do Crossplane (platform-apis/app), não o CI.
   Mesmos acessos via index/dig do kustomization.yaml.tmpl. */ -}}
{{- $http := true }}{{ if has .svc "http" }}{{ $http = .svc.http }}{{ end -}}
{{- $size := (index .svc "size") | default "small" -}}
{{- $caps := coll.Sort ((index .svc "capabilities") | default (coll.Slice)) -}}
{{- $env := (index .svc "env") | default (dict) -}}
# GENERATED pelo gitops-render a partir de {{ getenv "PROVENANCE" }} — NÃO EDITE.
# Mudanças manuais são sobrescritas no próximo render; a fonte da verdade
# é o service.yaml do repo de aplicação.
apiVersion: platform.lab/v1alpha1
kind: App
metadata:
  name: {{ .svc.name }}
spec:
  # Placeholder: o images transformer do kustomization wrapper troca por
  # ghcr.io/...:<tag> no build do Argo — a promoção de tag do ci-tag
  # continua dona da imagem, igual ao Caminho A.
  image: app-image
  size: {{ $size }}
  http: {{ $http }}
{{- if $env }}
  env:
{{- range $key, $value := $env }}
    {{ $key }}: {{ printf "%q" $value }}
{{- end }}
{{- end }}
{{- if $caps }}
  capabilities:
{{- range $caps }}
    - {{ . }}
{{- end }}
{{- end }}
